# =============================================
# App - Environment Configuration
# =============================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# Oracle Database (default dev credentials match docker-compose.yml)
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SID=XEPDB1
ORACLE_USER=db_admin
ORACLE_PASSWORD=db_secret_2024

# NextAuth Authentication
# NEXTAUTH_URL: Set to your actual production domain (e.g. https://assessment.example.com)
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET: Generate a strong random secret for production:
#   Run: openssl rand -base64 32
#   Or:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="change-this-secret-in-production"

# App Environment
# Set to "production" for deployment
NODE_ENV="development"
